{
  "name": "@claw/core",
  "version": "0.1.0",
  "description": "Core SDK for the CLAW_MACHINE self-improving agent framework on 0G",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["agent", "framework", "0g", "openclaw", "llm", "memory"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "ethers": "^6.13.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.3.0",
    "vitest": "^2.1.6"
  }
}
