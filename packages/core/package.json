{
  "name": "@claw/core",
  "version": "0.1.0",
  "description": "Core SDK for the CLAW_MACHINE self-improving agent framework on 0G",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "keywords": ["agent", "framework", "0g", "openclaw", "llm", "memory"],
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0"
  }
}
