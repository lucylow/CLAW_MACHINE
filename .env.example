# ── OpenAgents Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values

# ── Backend ────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# 0G Labs Network
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16600
OG_STORAGE_RPC=https://rpc-storage-testnet.0g.ai
OG_COMPUTE_RPC=https://rpc-compute-testnet.0g.ai

# Multimodal sealed inference (optional HTTP API). If unset, the backend uses a mock 0G multimodal client.
# ZERO_G_MULTIMODAL_ENDPOINT=https://your-multimodal-service.example/v1
# ZERO_G_MULTIMODAL_API_KEY=
MULTIMODAL_MEMORY_DIR=./data/multimodal-memory

# Agent private key (for signing transactions — NEVER commit this!)
AGENT_PRIVATE_KEY=0x...

# 0G Serving Broker
OG_SERVING_BROKER_ADDRESS=0x...

# ── Frontend (prefix with VITE_ for Vite to expose) ────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_OG_CHAIN_ID=16600
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_EXPLORER=https://chainscan-newton.0g.ai

# 0G frontend integration (optional HTTP gateways — set when using ZeroGStorage / ZeroGCompute)
# VITE_0G_KV=https://your-kv-service.example
# VITE_0G_LOG=https://your-log-service.example
# VITE_0G_BLOB=https://your-blob-service.example
# VITE_0G_COMPUTE=https://your-compute-service.example

# On-chain skill registry
SKILL_REGISTRY_ADDRESS=0x...
SKILL_REGISTRY_RPC_URL=https://evmrpc-testnet.0g.ai
SKILL_REGISTRY_CHAIN_ID=16600
# Optional signer used by backend skill-registry write routes
SKILL_REGISTRY_PRIVATE_KEY=0x...
